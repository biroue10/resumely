{
  "name": "applycraft",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite-react-ssg build",
    "preview": "vite preview",
    "seo:sitemap": "node scripts/generate-sitemap.mjs",
    "seo:audit": "bash scripts/seo-audit.sh",
    "seo:compare": "python3 scripts/compare-seo-pages.py",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "validate:seo": "SEO_AUDIT_SKIP_HTTP=1 bash scripts/seo-audit.sh",
    "validate:performance": "node scripts/validate-performance.mjs",
    "analyze": "ANALYZE=true npm run build",
    "test:a11y": "node scripts/a11y-check.mjs",
    "test:security": "node scripts/security-tests.mjs",
    "test:ux": "node scripts/ux-tests.mjs",
    "test:visual": "node scripts/visual-regression.mjs",
    "audit:high": "npm audit --audit-level=high"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "fflate": "^0.8.3",
    "jspdf": "^4.2.1",
    "lz-string": "^1.5.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "vite-react-ssg": "^0.9.1-beta.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "vite": "^6.4.3"
  }
}
